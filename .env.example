# Copy this file to .env and fill in your values
OPENAI_API_KEY=sk-...

# Twilio — find these at console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=whatsapp:+14155238886

# Telegram Bot — get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram chat IDs allowed to use the bot (empty = allow all)
TELEGRAM_ALLOWED_CHAT_IDS=

# Postgres — used by docker-compose to create the DB and build DATABASE_URL
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agentdb
